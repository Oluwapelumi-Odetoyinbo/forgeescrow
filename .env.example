# Deployed ForgeEscrow contract address on the LitVM LiteForge testnet
# Replace with the actual contract address after deployment
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# LitVM LiteForge testnet chain ID (decimal)
# Update with the official chain ID once confirmed for the LiteForge testnet
VITE_LITVM_CHAIN_ID=8888

# (Optional) RPC URL used when prompting MetaMask to add the LitVM network
VITE_LITVM_RPC_URL=https://rpc.testnet.litvm.org

# (Optional) Block explorer URL shown in MetaMask for the LitVM network
VITE_LITVM_EXPLORER_URL=https://explorer.testnet.litvm.org

# (Optional) Display name for the LitVM network
VITE_LITVM_NETWORK_NAME=LitVM LiteForge Testnet
