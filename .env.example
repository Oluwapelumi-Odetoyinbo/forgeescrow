# LitVM LiteForge Testnet Configuration
# Chain ID: 4441
# Explorer: https://liteforge.explorer.caldera.xyz
# Faucet: https://liteforge.hub.caldera.xyz

# Your deployer wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Second wallet for testing (freelancer wallet)
FREELANCER_PRIVATE_KEY=your_freelancer_private_key_here

# LitVM LiteForge Testnet RPC URL
LITVM_RPC_URL=https://rpc.liteforge.caldera.xyz

# Block explorer API key (optional for contract verification)
EXPLORER_API_KEY=

# Enable gas reporting (true/false)
REPORT_GAS=false
